# ─────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────

# Database
DB_URL=jdbc:postgresql://localhost:5432/notification
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_POOL_SIZE=10
DB_POOL_MIN_IDLE=2

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=notification-group
KAFKA_NOTIFICATION_TOPIC=notification-shards
KAFKA_TOPIC_PARTITIONS=10
KAFKA_TOPIC_REPLICAS=1

# Sharding
NOTIFICATION_BATCH_SIZE=10000

# JPA
JPA_DDL_AUTO=none
JPA_SHOW_SQL=false

# App
SERVER_PORT=8080
LOG_LEVEL=INFO
